{
    "name": "salonbw-backend",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "import:products": "ts-node --transpile-only scripts/import-products.ts",
        "import:services": "ts-node --transpile-only scripts/import-services.ts",
        "qa:reschedule-fixture": "node scripts/prepare-reschedule-fixture.js",
        "seed:test": "ts-node --transpile-only scripts/seed-test-data.ts",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/src/main",
        "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix --ignore-pattern \"**/*.spec.ts\"",
        "typecheck": "tsc --project tsconfig.build.json --noEmit",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "swagger:generate": "npx ts-node --project tsconfig.json swagger.ts",
        "db:migrate": "node dist/src/migrate"
    },
    "dependencies": {
        "@nestjs/axios": "^4.0.1",
        "@nestjs/common": "^11.1.27",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.1.28",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/mapped-types": "^2.1.1",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.27",
        "@nestjs/platform-socket.io": "^11.1.19",
        "@nestjs/schedule": "^6.0.1",
        "@nestjs/swagger": "^11.4.4",
        "@nestjs/throttler": "^6.5.0",
        "@nestjs/typeorm": "^11.0.3",
        "@nestjs/websockets": "^11.1.14",
        "@sentry/node": "^10.63.0",
        "@sentry/profiling-node": "^10.63.0",
        "axios": "^1.18.1",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "date-fns": "^4.4.0",
        "dotenv": "^17.4.2",
        "ioredis": "^5.10.1",
        "jimp": "^1.6.1",
        "multer": "^2.2.0",
        "nestjs-pino": "^4.6.0",
        "nodemailer": "^9.0.1",
        "passport": "^0.7.0",
        "passport-facebook": "^3.0.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.22.0",
        "pino": "^10.3.1",
        "prom-client": "^15.1.2",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "socket.io": "^4.8.1",
        "ts-node": "^10.9.2",
        "typeorm": "^0.3.29",
        "uuid": "^14.0.1",
        "web-push": "^3.6.7",
        "xml2js": "^0.6.2"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.2",
        "@nestjs/cli": "^11.0.23",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.1.27",
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.5",
        "@types/jest": "^30.0.0",
        "@types/multer": "^1.4.12",
        "@types/node": "^25.6.2",
        "@types/nodemailer": "^8.0.1",
        "@types/passport-facebook": "^3.0.4",
        "@types/passport-google-oauth20": "^2.0.17",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/socket.io-client": "^3.0.0",
        "@types/supertest": "^7.2.0",
        "@types/web-push": "^3.6.4",
        "@types/xml2js": "^0.4.14",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.7.0",
        "jest": "^30.2.0",
        "nock": "^14.0.10",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.9.4",
        "socket.io-client": "^4.8.1",
        "source-map-support": "^0.5.21",
        "sqlite3": "^5.1.7",
        "supertest": "^7.0.0",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.6.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
