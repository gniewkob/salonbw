{
    "name": "salonbw-monorepo",
    "private": true,
    "version": "0.0.0",
    "packageManager": "pnpm@10.14.0",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prepare": "husky install",
        "setup": "bash scripts/setup.sh",
        "lint": "pnpm -r run --if-present lint",
        "typecheck": "pnpm -r run --if-present typecheck",
        "format": "pnpm -r run --if-present format",
        "tunnel:start": "bash scripts/db-tunnel.sh",
        "tunnel:stop": "bash scripts/db-tunnel-kill.sh",
        "be:dev": "pnpm --filter salonbw-backend start:dev",
        "be:test": "pnpm --filter salonbw-backend test"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "pnpm exec eslint --fix"
        ],
        "*.{json,md,css,scss}": [
            "pnpm exec prettier --write"
        ]
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.21",
        "@nestjs/schematics": "^11.0.9",
        "@types/node": "^25.6.2",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "lint-staged": "^16.2.7",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "turbo": "^2.9.14",
        "typescript": "^5.9.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "cypress"
        ],
        "overrides": {
            "axios": "^1.15.2",
            "next": "15.5.18",
            "qs": ">=6.15.2",
            "validator": "^13.15.20",
            "tar-fs": "^3.0.5",
            "tar": ">=7.5.11",
            "glob": "^10.5.0",
            "cross-spawn": "^7.0.6",
            "micromatch": "^4.0.8",
            "nanoid": "^3.3.8",
            "path-to-regexp": "^0.1.13",
            "body-parser": "^1.20.3",
            "express": "^4.21.2",
            "cookie": "^0.7.2",
            "rand-token": "workspace:rand-token@1.0.1",
            "fast-xml-parser": ">=5.7.0",
            "fast-xml-builder": ">=1.1.7",
            "flatted": ">=3.4.0",
            "socket.io-parser": ">=4.2.6",
            "minimatch": "^3.1.5",
            "systeminformation": "^5.31.6",
            "rollup": "^4.59.0",
            "serialize-javascript": "^7.0.5",
            "handlebars": "^4.7.9",
            "fast-uri": "^3.1.2",
            "lodash": "^4.18.1",
            "ip-address": "^10.2.0",
            "follow-redirects": "^1.16.0",
    "ws": "^8.20.1",
    "ajv": "^8.20.0",
    "eslint>ajv": "6.14.0",
    "@eslint/eslintrc>ajv": "6.14.0",
    "js-cookie": ">=3.0.7",
    "yaml": ">=2.8.3",
    "uuid": "^11.1.1",
    "postcss": "^8.5.14",
            "min-document": "^2.19.1",
            "typeorm>uuid": "^11.1.1",
            "micromatch>picomatch": "^2.3.2",
            "anymatch>picomatch": "^2.3.2",
            "tinyglobby>picomatch": "^4.0.4",
            "@angular-devkit/core>picomatch": "^4.0.4",
            "jest-util>picomatch": "^4.0.4",
            "@rollup/pluginutils>picomatch": "^4.0.4",
            "@rollup/plugin-commonjs>picomatch": "^4.0.4",
            "http-proxy-agent>@tootallnate/once": "^3.0.1"
        },
        "auditConfig": {
            "ignoreCves": [
                "CVE-2023-30533",
                "CVE-2024-22363"
            ]
        }
    }
}
